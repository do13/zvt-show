{
  "name": "zvt-analyzer",
  "version": "1.3.0",
  "description": "ZVT ECR-Interface Protocol Analyzer",
  "author": "Dirk Opfer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder --win --x64",
    "lint": "eslint zvt.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.zvt.analyzer",
    "productName": "ZVT Analyzer",
    "win": {
      "target": "portable"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "node_modules/electron-unhandled/**/*"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.1",
    "electron-reload": "^1.5.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "electron-unhandled": "^5.0.0"
  }
}
